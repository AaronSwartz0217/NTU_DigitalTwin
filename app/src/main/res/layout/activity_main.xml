<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <!-- 顶部标题栏 - 默认隐藏 -->
    <LinearLayout
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#0d2a3f"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="15dp"
        android:visibility="gone">

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="#1a5f7f" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="15dp"
            android:text="南通大学启东校区数字孪生平台"
            android:textColor="#00ffff"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="#1a5f7f" />

        <Button
            android:id="@+id/btn_hide_title"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="隐藏"
            android:textSize="12sp"
            android:textColor="#ffffff"
            android:background="@drawable/panel_background" />

    </LinearLayout>

    <!-- 主内容区域：WebView全屏作为背景，侧边栏悬浮在上面 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- WebView 全屏显示作为背景 -->
        <FrameLayout
            android:id="@+id/webview_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- WebView 用于展示 GitHub Pages -->
            <WebView
                android:id="@+id/webview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="visible" />

            <!-- 加载错误视图 -->
            <LinearLayout
                android:id="@+id/error_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#000000"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/error_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="模型加载失败"
                    android:textColor="#ff6666"
                    android:textSize="18sp" />

                <Button
                    android:id="@+id/btn_retry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="重试"
                    android:backgroundTint="#00ffff" />

            </LinearLayout>

        </FrameLayout>

        <!-- 悬浮层：顶部标题框（置顶居中） -->
        <LinearLayout
            android:id="@+id/top_title_box"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center"
            android:layout_marginTop="5dp"
            android:background="@drawable/panel_background_transparent"
            android:padding="6dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="南通大学启东校区可视化"
                android:textColor="#00ffff"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- 悬浮层：左侧面板 -->
        <LinearLayout
            android:id="@+id/left_panel"
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:layout_gravity="left"
            android:orientation="vertical"
            android:padding="6dp"
            android:visibility="visible"
            android:background="#0d0d2a3f"
            android:alpha="0.9">

            <!-- 左侧上：天气信息卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:background="@drawable/panel_background_transparent"
                android:orientation="vertical"
                android:padding="6dp">

                <TextView
                    android:id="@+id/tv_temperature"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--°C"
                    android:textColor="#ffffff"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tv_weather_condition"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="等待更新"
                    android:textColor="#00ffff"
                    android:textSize="10sp"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="湿度"
                        android:textColor="#88cccc"
                        android:textSize="7sp" />
                    <TextView
                        android:id="@+id/tv_humidity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="2dp"
                        android:text="--%"
                        android:textColor="#ffffff"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="4dp"
                        android:text="风速"
                        android:textColor="#88cccc"
                        android:textSize="7sp" />
                    <TextView
                        android:id="@+id/tv_wind_speed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="2dp"
                        android:text="--"
                        android:textColor="#ffffff"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="4dp"
                        android:text="体感"
                        android:textColor="#88cccc"
                        android:textSize="7sp" />
                    <TextView
                        android:id="@+id/tv_feels_like"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="2dp"
                        android:text="--°C"
                        android:textColor="#ffffff"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/weather_loading"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"
                    android:indeterminateTint="#00ffff"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- 左侧下：数据概览 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/panel_background_transparent"
                android:orientation="vertical"
                android:padding="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="数据概览"
                    android:textColor="#00ffff"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:id="@+id/stats_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="4dp"
                        android:layout_marginBottom="2dp"
                        android:background="#0d0d2a4f">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="累计访问"
                            android:textColor="#88cccc"
                            android:textSize="8sp" />

                        <TextView
                            android:id="@+id/tv_total_visits"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#00ffff"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="4dp"
                        android:layout_marginBottom="2dp"
                        android:background="#0d0d2a4f">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="今日访问"
                            android:textColor="#88cccc"
                            android:textSize="8sp" />

                        <TextView
                            android:id="@+id/tv_today_visits"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#00ffff"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="4dp"
                        android:layout_marginBottom="2dp"
                        android:background="#0d0d2a4f">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="平均温度"
                            android:textColor="#88cccc"
                            android:textSize="8sp" />

                        <TextView
                            android:id="@+id/tv_avg_temp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--°C"
                            android:textColor="#00ffff"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="4dp"
                        android:background="#0d0d2a4f">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="更新时间"
                            android:textColor="#88cccc"
                            android:textSize="8sp" />

                        <TextView
                            android:id="@+id/tv_update_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--:--"
                            android:textColor="#00ffff"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- 查询功能区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/panel_background_transparent"
                android:orientation="vertical"
                android:padding="6dp"
                android:layout_marginTop="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="建筑查询"
                    android:textColor="#00ffff"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <!-- 搜索栏 -->
                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="输入建筑名称"
                    android:textColor="#ffffff"
                    android:textSize="9sp"
                    android:textColorHint="#66cccc"
                    android:background="@drawable/search_bar_background"
                    android:padding="6dp"
                    android:layout_marginBottom="4dp" />

                <!-- 分类选择 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="4dp">

                    <RadioGroup
                        android:id="@+id/rg_category"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <RadioButton
                            android:id="@+id/rb_dormitory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="宿舍"
                            android:textColor="#88cccc"
                            android:textSize="8sp"
                            android:buttonTint="#00ffff"
                            android:layout_marginRight="10dp" />

                        <RadioButton
                            android:id="@+id/rb_teaching"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="教学"
                            android:textColor="#88cccc"
                            android:textSize="8sp"
                            android:buttonTint="#00ffff" />

                    </RadioGroup>

                </LinearLayout>

                <!-- 搜索按钮 -->
                <Button
                    android:id="@+id/btn_search"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="搜索"
                    android:textSize="10sp"
                    android:textColor="#ffffff"
                    android:background="@drawable/button_transparent_round" />

            </LinearLayout>

        </LinearLayout>

        <!-- 悬浮层：右侧面板 -->
        <LinearLayout
            android:id="@+id/right_panel"
            android:layout_width="220dp"
            android:layout_height="match_parent"
            android:layout_gravity="right"
            android:orientation="vertical"
            android:padding="8dp"
            android:visibility="visible"
            android:background="#0d0d2a3f"
            android:alpha="0.9">

            <!-- 温度折线图 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="2"
                android:background="@drawable/panel_background_transparent"
                android:orientation="vertical"
                android:padding="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="温度趋势"
                    android:textColor="#00ffff"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="2dp" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/line_chart"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="4dp">

                    <Button
                        android:id="@+id/btn_today"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="今日"
                        android:textSize="9sp"
                        android:textColor="#ffffff"
                        android:background="@drawable/button_transparent_round"
                        android:layout_marginRight="4dp" />

                    <Button
                        android:id="@+id/btn_week"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="本周"
                        android:textSize="9sp"
                        android:textColor="#88cccc"
                        android:background="@drawable/button_transparent_round"
                        android:layout_marginLeft="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- 历史记录 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1.5"
                android:background="@drawable/panel_background_transparent"
                android:orientation="vertical"
                android:padding="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="历史记录"
                    android:textColor="#00ffff"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/history_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </ScrollView>

            </LinearLayout>

        </LinearLayout>

        <!-- 底部控制按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="10dp">

            <Button
                android:id="@+id/btn_refresh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="80dp"
                android:text="刷新"
                android:textSize="11sp"
                android:textColor="#00ffff"
                android:background="@drawable/button_transparent_round"
                android:layout_marginRight="10dp" />

            <Button
                android:id="@+id/btn_forum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="80dp"
                android:text="论坛"
                android:textSize="11sp"
                android:textColor="#00ffff"
                android:background="@drawable/button_transparent_round"
                android:layout_marginRight="10dp" />

            <Button
                android:id="@+id/btn_toggle_panels"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="80dp"
                android:text="隐藏"
                android:textSize="11sp"
                android:textColor="#00ffff"
                android:background="@drawable/button_transparent_round" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="10dp">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="10dp"
        android:background="@drawable/panel_background_transparent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="启东校区论坛"
            android:textColor="#00ffff"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <Button
            android:id="@+id/btn_enter_digital_twin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="进入数字孪生"
            android:textSize="12sp"
            android:textColor="#ffffff"
            android:background="@drawable/button_transparent_round"
            android:minWidth="100dp" />

    </LinearLayout>

    <!-- 帖子列表 -->
    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="10dp">

        <LinearLayout
            android:id="@+id/posts_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

    <!-- 发布区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="10dp"
        android:background="@drawable/panel_background_transparent"
        android:padding="10dp">

        <EditText
            android:id="@+id/et_post_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:hint="输入帖子内容..."
            android:textColorHint="#88cccc"
            android:textColor="#ffffff"
            android:background="#1a1a3a4f"
            android:padding="8dp"
            android:gravity="top"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_post"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="发布"
            android:textSize="12sp"
            android:textColor="#00ffff"
            android:background="@drawable/button_transparent_round"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8FAFC">

    <!-- ========== 简洁顶部栏 ========== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/profile_header_bg"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="44dp"
        android:paddingBottom="18dp">

        <!-- 导航行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <FrameLayout
                android:id="@+id/btn_menu"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/icon_circle_white_alpha"
                android:gravity="center">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_menu"
                    android:layout_gravity="center" />

            </FrameLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/avatar_small_bg"
                android:gravity="center">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_user_avatar"
                    android:layout_gravity="center" />

            </FrameLayout>

        </LinearLayout>

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="校园论坛"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/tv_welcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="分享你的校园生活"
            android:textColor="#C7D2FE"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- ========== 需要登录的提示界面（默认显示） ========== -->
    <LinearLayout
        android:id="@+id/login_required_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="#F8FAFC"
        android:visibility="gone">

        <!-- 锁定图标背景 -->
        <View
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/icon_circle_blue"
            android:alpha="0.3" />

        <!-- 论坛图标 -->
        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_nav_home"
            android:layout_marginTop="-58dp"
            android:layout_marginBottom="24dp" />

        <!-- 提示标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="需要登录才能使用论坛"
            android:textColor="#1E293B"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- 提示说明 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="登录后即可浏览和发布校园论坛帖子\n与其他同学分享你的校园生活"
            android:textColor="#64748B"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="32dp" />

        <!-- 去登录按钮 -->
        <TextView
            android:id="@+id/btn_go_to_login_forum"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="去登录"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/button_blue"
            android:paddingStart="36dp"
            android:paddingEnd="36dp"
            android:elevation="2dp" />

    </LinearLayout>

    <!-- ========== 主内容区（默认隐藏） ========== -->
    <ScrollView
        android:id="@+id/forum_content_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="14dp">

            <!-- 标签栏 -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/tag_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tag_all"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="全部"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:paddingLeft="18dp"
                        android:paddingRight="18dp"
                        android:background="@drawable/tag_selected" />

                    <TextView
                        android:id="@+id/tag_hot"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="热门"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:paddingLeft="18dp"
                        android:paddingRight="18dp"
                        android:background="@drawable/tag_unselected_modern"
                        android:layout_marginStart="8dp" />

                    <TextView
                        android:id="@+id/tag_new"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="最新"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:paddingLeft="18dp"
                        android:paddingRight="18dp"
                        android:background="@drawable/tag_unselected_modern"
                        android:layout_marginStart="8dp" />

                    <TextView
                        android:id="@+id/tag_my"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="我的"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:paddingLeft="18dp"
                        android:paddingRight="18dp"
                        android:background="@drawable/tag_unselected_modern"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

            </HorizontalScrollView>

            <!-- 帖子列表容器 -->
            <LinearLayout
                android:id="@+id/posts_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="14dp" />

        </LinearLayout>

    </ScrollView>

    <!-- ========== 悬浮加号按钮 ========== -->
    <ImageButton
        android:id="@+id/btn_new_post"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:src="@drawable/ic_add"
        android:scaleType="fitCenter"
        android:background="@drawable/add_button_bg"
        android:elevation="6dp"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="90dp" />

    <!-- ========== 发帖弹窗 ========== -->
    <LinearLayout
        android:id="@+id/post_dialog_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F8FAFC"
        android:visibility="gone"
        android:elevation="16dp">

        <!-- 弹窗顶部 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp">

            <Button
                android:id="@+id/btn_cancel_post"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:text="✕"
                android:textColor="#64748B"
                android:textSize="18sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="发布新帖"
                android:textColor="#1E293B"
                android:textSize="17sp"
                android:textStyle="bold"
                android:gravity="center" />

            <Button
                android:id="@+id/btn_post"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="发布"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_blue"
                android:paddingLeft="24dp"
                android:paddingRight="24dp"
                android:minHeight="0dp"
                android:minWidth="0dp" />

        </LinearLayout>

        <!-- 编辑区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingRight="20dp">

            <EditText
                android:id="@+id/et_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="输入标题..."
                android:textColorHint="#94A3B8"
                android:textColor="#1E293B"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="@null"
                android:paddingTop="20dp"
                android:paddingBottom="12dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E2E8F0" />

            <EditText
                android:id="@+id/et_content"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:hint="分享你的想法..."
                android:textColorHint="#94A3B8"
                android:textColor="#334155"
                android:background="@null"
                android:paddingTop="16dp"
                android:gravity="top"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.6" />

        </LinearLayout>

    </LinearLayout>

    <!-- ========== 帖子详情 ========== -->
    <LinearLayout
        android:id="@+id/post_detail_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F8FAFC"
        android:visibility="gone">

        <!-- 详情顶部 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back_arrow"
                android:scaleType="fitCenter"
                android:padding="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="帖子详情"
                android:textColor="#1E293B"
                android:textSize="17sp"
                android:textStyle="bold"
                android:paddingStart="12dp" />

        </LinearLayout>

        <!-- 详情内容 -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="80dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="12dp">

                <!-- 帖子内容卡片 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_background"
                    android:padding="20dp"
                    android:elevation="2dp">

                    <!-- 标题 -->
                    <TextView
                        android:id="@+id/tv_detail_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#1E293B"
                        android:textSize="19sp"
                        android:textStyle="bold"
                        android:lineSpacingMultiplier="1.35" />

                    <!-- 作者信息 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="14dp"
                        android:paddingBottom="4dp"
                        android:gravity="center_vertical">

                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/avatar_small_bg">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_user_avatar"
                                android:layout_gravity="center" />

                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_detail_author"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#475569"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:paddingStart="10dp" />

                        <TextView
                            android:id="@+id/tv_detail_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#94A3B8"
                            android:textSize="12sp"
                            android:paddingStart="10dp" />

                    </LinearLayout>

                    <!-- 内容 -->
                    <TextView
                        android:id="@+id/tv_detail_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#334155"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.65"
                        android:paddingTop="12dp" />

                    <!-- 互动数据 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="16dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_detail_likes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#64748B"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_detail_comments"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#64748B"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:paddingStart="18dp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- 评论标题 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="18dp"
                        android:background="@drawable/indicator_bar" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="评论"
                        android:textColor="#1E293B"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:paddingStart="10dp" />

                </LinearLayout>

                <!-- 评论列表 -->
                <LinearLayout
                    android:id="@+id/comments_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- 评论输入框 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/card_background"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:layout_marginTop="14dp"
                    android:elevation="2dp">

                    <EditText
                        android:id="@+id/et_comment"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="写评论..."
                        android:textColorHint="#94A3B8"
                        android:textColor="#334155"
                        android:textSize="14sp"
                        android:background="@null"
                        android:maxLines="3"
                        android:inputType="textMultiLine" />

                    <Button
                        android:id="@+id/btn_comment"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="发送"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/button_blue"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp"
                        android:minHeight="0dp"
                        android:minWidth="0dp" />

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</LinearLayout>

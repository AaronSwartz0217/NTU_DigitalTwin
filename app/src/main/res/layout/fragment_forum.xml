<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient_background">

    <!-- 顶部导航栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/btn_menu"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_menu" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/avatar_bg">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_user_avatar"
                android:layout_gravity="center" />

        </FrameLayout>

    </LinearLayout>

    <!-- 主内容区域 - 可滚动 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingBottom="100dp">

            <!-- 欢迎文字 -->
            <TextView
                android:id="@+id/tv_welcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome back!"
                android:textColor="#6B7280"
                android:textSize="15sp" />

            <!-- 大标题 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="数字孪生平台"
                android:textColor="#111827"
                android:textSize="28sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.2"
                android:paddingTop="8dp"
                android:paddingBottom="20dp" />

            <!-- 标签栏 -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/tag_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tag_all"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="全部"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:paddingLeft="20dp"
                        android:paddingRight="20dp"
                        android:background="@drawable/tag_selected" />

                    <TextView
                        android:id="@+id/tag_hot"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="热门"
                        android:textColor="#6B7280"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:paddingLeft="20dp"
                        android:paddingRight="20dp"
                        android:background="@drawable/tag_unselected"
                        android:layout_marginLeft="10dp" />

                    <TextView
                        android:id="@+id/tag_new"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="最新"
                        android:textColor="#6B7280"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:paddingLeft="20dp"
                        android:paddingRight="20dp"
                        android:background="@drawable/tag_unselected"
                        android:layout_marginLeft="10dp" />

                    <TextView
                        android:id="@+id/tag_my"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="我的"
                        android:textColor="#6B7280"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:paddingLeft="20dp"
                        android:paddingRight="20dp"
                        android:background="@drawable/tag_unselected"
                        android:layout_marginLeft="10dp" />

                </LinearLayout>

            </HorizontalScrollView>

            <!-- 帖子统计卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/main_card_bg"
                android:padding="24dp"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="平台动态总览"
                        android:textColor="#374151"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:lineSpacingMultiplier="1.3" />

                    <TextView
                        android:id="@+id/tv_post_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 篇帖子"
                        android:textColor="#6B7280"
                        android:textSize="14sp"
                        android:paddingTop="8dp"
                        android:paddingBottom="12dp" />

                    <Button
                        android:id="@+id/btn_new_post"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="发布新帖"
                        android:textColor="#111827"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:background="@drawable/btn_start_bg"
                        android:paddingLeft="24dp"
                        android:paddingRight="24dp"
                        android:minHeight="0dp"
                        android:minWidth="0dp" />

                </LinearLayout>

                <View
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/play_icon_bg" />

            </LinearLayout>

            <!-- 推荐区域标题 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="最新帖子"
                android:textColor="#111827"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="16dp" />

            <!-- 帖子列表容器 -->
            <LinearLayout
                android:id="@+id/posts_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

    </ScrollView>

    <!-- 发帖弹窗 -->
    <LinearLayout
        android:id="@+id/post_dialog_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F8F9FC"
        android:visibility="gone"
        android:elevation="16dp">

        <!-- 弹窗顶部 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="20dp">

            <Button
                android:id="@+id/btn_cancel_post"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/btn_back"
                android:text="←"
                android:textColor="#111827"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="发布新帖"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center" />

            <View
                android:layout_width="40dp"
                android:layout_height="40dp" />

        </LinearLayout>

        <!-- 编辑区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingRight="20dp">

            <EditText
                android:id="@+id/et_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="输入标题..."
                android:textColorHint="#9CA3AF"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="@null"
                android:paddingTop="12dp"
                android:paddingBottom="12dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E7EB" />

            <EditText
                android:id="@+id/et_content"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:hint="分享你的想法..."
                android:textColorHint="#9CA3AF"
                android:textColor="#374151"
                android:background="@null"
                android:paddingTop="16dp"
                android:gravity="top"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.5" />

            <Button
                android:id="@+id/btn_post"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="发布"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_blue"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="30dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- 帖子详情 -->
    <LinearLayout
        android:id="@+id/post_detail_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/gradient_background"
        android:visibility="gone">

        <!-- 详情顶部 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="20dp">

            <Button
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/btn_back"
                android:text="←"
                android:textColor="#111827"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginRight="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="帖子详情"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- 详情内容 -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:paddingBottom="100dp">

                <!-- 帖子内容卡片 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_background"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/tv_detail_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#111827"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:lineSpacingMultiplier="1.3" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="14dp"
                        android:paddingBottom="4dp"
                        android:gravity="center_vertical">

                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/avatar_bg">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_user_avatar"
                                android:layout_gravity="center" />

                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_detail_author"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#4B5563"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:paddingStart="10dp" />

                        <TextView
                            android:id="@+id/tv_detail_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#9CA3AF"
                            android:textSize="13sp"
                            android:paddingStart="12dp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_detail_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#374151"
                        android:textSize="15sp"
                        android:lineSpacingMultiplier="1.6"
                        android:paddingTop="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="18dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_detail_likes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#6B7280"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_detail_comments"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#6B7280"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:paddingStart="20dp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- 评论标题 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="评论"
                    android:textColor="#111827"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="16dp" />

                <!-- 评论列表 -->
                <LinearLayout
                    android:id="@+id/comments_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- 评论输入框 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_background"
                    android:padding="20dp"
                    android:layout_marginTop="20dp">

                    <EditText
                        android:id="@+id/et_comment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="70dp"
                        android:hint="写下你的评论..."
                        android:textColorHint="#9CA3AF"
                        android:textColor="#111827"
                        android:background="@null"
                        android:textSize="14sp"
                        android:gravity="top" />

                    <Button
                        android:id="@+id/btn_comment"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="发表评论"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/button_blue"
                        android:layout_marginTop="14dp" />

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FC">

    <!-- ========== 未登录状态 ========== -->
    <LinearLayout
        android:id="@+id/login_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F8F9FC">

        <!-- 顶部渐变区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:background="@drawable/profile_header_bg"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingBottom="40dp">

            <!-- Logo图标 -->
            <FrameLayout
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:background="@drawable/avatar_large_bg"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_user_avatar"
                    android:layout_gravity="center" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="南通大学启东校区"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="数字孪生平台"
                android:textColor="#E0E7FF"
                android:textSize="14sp"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        <!-- 登录卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:paddingTop="32dp">

            <!-- 登录提示 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="登录后解锁更多功能"
                android:textColor="#6B7280"
                android:textSize="15sp"
                android:layout_marginBottom="20dp" />

            <!-- 功能预览卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_background"
                android:padding="20dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_nav_home"
                        android:background="@drawable/icon_circle_purple"
                        android:padding="7dp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="发帖互动"
                        android:textColor="#374151"
                        android:textSize="12sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_nav_user"
                        android:background="@drawable/icon_circle_blue"
                        android:padding="7dp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="收藏管理"
                        android:textColor="#374151"
                        android:textSize="12sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_nav_bell"
                        android:background="@drawable/icon_circle_green"
                        android:padding="7dp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="个性化"
                        android:textColor="#374151"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- 登录按钮 -->
            <Button
                android:id="@+id/btn_login"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="立即登录"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_blue"
                android:elevation="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="初始账号密码: 1 / 1"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:layout_marginTop="14dp"
                android:layout_gravity="center" />

            <!-- 服务器设置（未登录时也可访问） -->
            <Button
                android:id="@+id/btn_server_settings"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="⚙ 服务器设置 (模拟器/真机切换)"
                android:textSize="13sp"
                android:textColor="#6B7280"
                android:background="@android:color/transparent"
                android:elevation="0dp"
                android:layout_marginTop="24dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ========== 已登录状态 ========== -->
    <ScrollView
        android:id="@+id/profile_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 顶部个人信息区 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/profile_header_bg"
                android:orientation="vertical"
                android:paddingLeft="24dp"
                android:paddingRight="24dp"
                android:paddingTop="48dp"
                android:paddingBottom="32dp"
                android:gravity="center_horizontal">

                <!-- 头像 -->
                <FrameLayout
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:background="@drawable/avatar_large_bg"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:src="@drawable/ic_user_avatar"
                        android:layout_gravity="center" />

                </FrameLayout>

                <!-- 昵称 -->
                <TextView
                    android:id="@+id/tv_nickname"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="用户昵称"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <!-- ID -->
                <TextView
                    android:id="@+id/tv_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ID: user"
                    android:textColor="#C7D2FE"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp" />

                <!-- 修改昵称按钮 -->
                <Button
                    android:id="@+id/btn_change_nickname"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="编辑资料"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/button_outline_white"
                    android:paddingLeft="24dp"
                    android:paddingRight="24dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:layout_marginTop="14dp" />

            </LinearLayout>

            <!-- 数据统计卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_background"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:layout_marginTop="-24dp"
                android:elevation="4dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_post_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#111827"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="帖子"
                        android:textColor="#9CA3AF"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="36dp"
                    android:background="#E5E7EB" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_like_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#111827"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="获赞"
                        android:textColor="#9CA3AF"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="36dp"
                    android:background="#E5E7EB" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_visit_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#111827"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="访问"
                        android:textColor="#9CA3AF"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- 学生档案信息卡片 -->
            <LinearLayout
                android:id="@+id/profile_info_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_background"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <!-- 标题 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="学生档案"
                    android:textColor="#6366F1"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:paddingBottom="12dp" />

                <!-- 第一行：学号 + 姓名 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:paddingBottom="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="学号"
                            android:textColor="#9CA3AF"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tv_user_no_display"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="未填写"
                            android:textColor="#374151"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="姓名"
                            android:textColor="#9CA3AF"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tv_user_name_display"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="未填写"
                            android:textColor="#374151"
                            android:textSize="14sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- 第二行：性别 + 民族 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:paddingBottom="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="性别"
                            android:textColor="#9CA3AF"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tv_gender_display"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="未填写"
                            android:textColor="#374151"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="民族"
                            android:textColor="#9CA3AF"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tv_ethnic_group_display"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="未填写"
                            android:textColor="#374151"
                            android:textSize="14sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- 第三行：籍贯 + 生日 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:paddingBottom="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="籍贯"
                            android:textColor="#9CA3AF"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tv_native_place_display"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="未填写"
                            android:textColor="#374151"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="生日"
                            android:textColor="#9CA3AF"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tv_birthday_display"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="未填写"
                            android:textColor="#374151"
                            android:textSize="14sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- 第四行：体重 + 身高 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:paddingBottom="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="体重"
                            android:textColor="#9CA3AF"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tv_weight_display"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="未填写"
                            android:textColor="#374151"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="身高"
                            android:textColor="#9CA3AF"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tv_height_display"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="未填写"
                            android:textColor="#374151"
                            android:textSize="14sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- 第五行：身份证号（单独一行） -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="身份证号"
                        android:textColor="#9CA3AF"
                        android:textSize="11sp"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tv_id_number_display"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="未填写"
                        android:textColor="#374151"
                        android:textSize="14sp" />

                </LinearLayout>

                <!-- 用户ID（隐藏字段，用于内部使用） -->
                <TextView
                    android:id="@+id/tv_user_id_display"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:text="" />

            </LinearLayout>

            <!-- 功能菜单组 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/card_background"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <!-- 我的帖子 -->
                <LinearLayout
                    android:id="@+id/menu_my_posts"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_nav_home"
                        android:background="@drawable/icon_circle_purple"
                        android:padding="6dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="我的帖子"
                        android:textColor="#374151"
                        android:textSize="15sp"
                        android:paddingStart="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        android:textColor="#D1D5DB"
                        android:textSize="16sp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F3F4F6"
                    android:layout_marginLeft="56dp" />

                <!-- 收藏夹 -->
                <LinearLayout
                    android:id="@+id/menu_favorites"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_nav_user"
                        android:background="@drawable/icon_circle_yellow"
                        android:padding="6dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="收藏夹"
                        android:textColor="#374151"
                        android:textSize="15sp"
                        android:paddingStart="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        android:textColor="#D1D5DB"
                        android:textSize="16sp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F3F4F6"
                    android:layout_marginLeft="56dp" />

                <!-- 浏览历史 -->
                <LinearLayout
                    android:id="@+id/menu_history"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_nav_calendar"
                        android:background="@drawable/icon_circle_green"
                        android:padding="6dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="浏览历史"
                        android:textColor="#374151"
                        android:textSize="15sp"
                        android:paddingStart="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        android:textColor="#D1D5DB"
                        android:textSize="16sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- 第二组菜单 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_background"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <!-- 设置 -->
                <LinearLayout
                    android:id="@+id/btn_settings"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_settings"
                        android:background="@drawable/icon_circle_gray"
                        android:padding="6dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="设置"
                        android:textColor="#374151"
                        android:textSize="15sp"
                        android:paddingStart="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        android:textColor="#D1D5DB"
                        android:textSize="16sp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F3F4F6"
                    android:layout_marginLeft="56dp" />

                <!-- 关于 -->
                <LinearLayout
                    android:id="@+id/btn_about"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_nav_bell"
                        android:background="@drawable/icon_circle_blue"
                        android:padding="6dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="关于我们"
                        android:textColor="#374151"
                        android:textSize="15sp"
                        android:paddingStart="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="v1.0.4"
                        android:textColor="#9CA3AF"
                        android:textSize="12sp"
                        android:paddingEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        android:textColor="#D1D5DB"
                        android:textSize="16sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- 退出登录按钮 -->
            <Button
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="退出登录"

<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    
    <!-- 高度透明背景颜色 - 透明度5% -->
    <solid android:color="#0d0d2a3f" />
    
    <!-- 半透明边框 - 透明度20% -->
    <stroke
        android:width="1dp"
        android:color="#3300ffff" />
    
    <!-- 圆角 -->
    <corners android:radius="6dp" />
    
    <!-- 内边距 -->
    <padding
        android:left="6dp"
        android:top="6dp"
        android:right="6dp"
        android:bottom="6dp" />
    
</shape>
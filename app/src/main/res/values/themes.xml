<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NTUQidongDigitalTwin" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/primary_dark</item>
        <item name="android:windowBackground">@color/white</item>
    </style>

    <style name="ToolbarStyle">
        <item name="android:background">@color/primary</item>
        <item name="android:elevation">4dp</item>
    </style>

    <style name="WeatherBarStyle">
        <item name="android:background">@color/weather_bg</item>
        <item name="android:padding">8dp</item>
    </style>

    <style name="MenuButtonStyle">
        <item name="android:textColor">@color/white</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:padding">8dp</item>
    </style>

    <!-- 启动页主题 -->
    <style name="Theme.Splash" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/splash_bg</item>
    </style>
</resources>

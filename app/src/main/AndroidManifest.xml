<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 网络权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".NTUQidongApp"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.NTUQidongDigitalTwin"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:requestLegacyExternalStorage="true">

        <!-- MainContainerActivity: 主容器Activity（底部导航） -->
        <activity
            android:name=".ui.MainContainerActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- SplashActivity: 数字孪生过渡动画（横屏） -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="false"
            android:theme="@style/Theme.Splash"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <!-- MainActivity: WebView 主界面（横屏数字孪生） -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:hardwareAccelerated="true"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:launchMode="singleTask" />

        <!-- StatisticsActivity: 统计页面 -->
        <activity
            android:name=".ui.StatisticsActivity"
            android:exported="false"
            android:hardwareAccelerated="true"
            android:parentActivityName=".ui.MainActivity" />

        <!-- ForumActivity: 旧版论坛页面（保留兼容） -->
        <activity
            android:name=".ui.ForumActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden" />

    </application>

</manifest>